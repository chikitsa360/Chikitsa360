# Copy this file to .env.local and fill in your values.
# See DEMO_SETUP.md at the repo root for step-by-step instructions.

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Client slug — controls branding. Options: chikitsa360 | cliniqly | mediflow
# Add new clients: packages/branding/src/themes/<slug>.ts
NEXT_PUBLIC_CLIENT_ID=chikitsa360

# ─── Auth (NextAuth v5) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Must match your deployed URL exactly (no trailing slash). On Vercel set to your
# production domain, e.g. https://cliniqly.vercel.app or https://app.cliniqly.in
AUTH_URL=https://your-domain.vercel.app

# ─── Database (Neon / PostgreSQL) ───────────────────────────────────────────────
# Free tier: https://neon.tech  — use ap-southeast-1 (Singapore) region
#
# TWO connection strings are required:
#   DATABASE_URL         → Pooled connection (via PgBouncer). Used by the app at runtime.
#                          Format: ep-xxx-pooler.ap-southeast-1.aws.neon.tech
#   DATABASE_URL_UNPOOLED → Direct connection. Used by prisma migrate and schema provisioning.
#                          Format: ep-xxx.ap-southeast-1.aws.neon.tech  (no "-pooler")
#
# In Neon dashboard: Project → Connection Details → toggle "Pooled connection" on/off
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────────
# Free tier: https://upstash.com — use ap-southeast-1 (Singapore) region
# Used for: WhatsApp conversation state (30-min TTL), rate limiting, OTP storage
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Real-time (Pusher) ──────────────────────────────────────────────────────────
# Free tier: https://pusher.com — use ap2 (Mumbai) cluster
# Used for: live calendar updates, appointment status changes
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_KEY=        # same as PUSHER_KEY
NEXT_PUBLIC_PUSHER_CLUSTER=ap2 # same as PUSHER_CLUSTER

# ─── Background jobs (Inngest) ───────────────────────────────────────────────────
# Free tier: https://inngest.com
# Used for: WhatsApp reminders (24h + 2h), confirmations, SMS fallback, slot release
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────────
# Setup guide: https://developers.facebook.com → create app → add WhatsApp product
# For demo: use the test phone number Meta provides (no business verification needed)
# For production: clinic enters their own phone number ID during onboarding wizard
META_SYSTEM_ACCESS_TOKEN=     # WhatsApp → API Setup → Access Token
META_APP_SECRET=              # App Settings → Basic → App Secret
NEXT_PUBLIC_FACEBOOK_APP_ID=  # App Settings → Basic → App ID
WHATSAPP_VERIFY_TOKEN=        # Any random string — must match what you enter in Meta webhook settings

# ─── SMS Fallback (MSG91) ────────────────────────────────────────────────────────
# Optional for demo. Required for production to handle WhatsApp delivery failures.
# https://msg91.com — free trial includes credits
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CLNQLY
MSG91_TEMPLATE_ID=

# ─── Web Push Notifications (VAPID) ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY goes in both server and client (NEXT_PUBLIC_ prefix)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # same as VAPID_PUBLIC_KEY
VAPID_EMAIL=mailto:support@cliniqly.com

# ─── Development Only ─────────────────────────────────────────────────────────
# Set a fixed OTP bypass code for local testing (ignored in production).
# With this set, any phone number will accept this code on the login screen.
# DEV_OTP_BYPASS=123456
