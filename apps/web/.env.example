# ─── Multi-Tenant Branding ───────────────────────────────────────────────────
# Set this to the client's slug to load their branding.
# Available: cliniqly (default), mediflow
# Add new clients by creating packages/branding/src/themes/<slug>.ts
NEXT_PUBLIC_CLIENT_ID=cliniqly

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── API ──────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000
