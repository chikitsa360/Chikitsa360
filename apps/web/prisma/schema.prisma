generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Public schema models ───────────────────────────────────────────────────

enum UserRole {
  OWNER
  DOCTOR
  RECEPTIONIST
}

enum ClinicPlan {
  STARTER
  GROWTH
  PRO
}

enum ClinicLanguage {
  en
  hi
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Clinic {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  plan          ClinicPlan  @default(STARTER)
  trialEndsAt   DateTime?   @map("trial_ends_at")
  onboardingComplete Boolean @default(false) @map("onboarding_complete")
  onboardingStep    Int      @default(1) @map("onboarding_step")
  createdAt     DateTime    @default(now()) @map("created_at")

  // Clinic profile fields
  address         String?
  city            String?
  speciality      String?
  clinicPhone     String?   @map("clinic_phone")

  // Legal acceptance timestamps (UTC)
  tosAcceptedAt     DateTime? @map("tos_accepted_at")
  privacyAcceptedAt DateTime? @map("privacy_accepted_at")
  dpaAcceptedAt     DateTime? @map("dpa_accepted_at")

  // Language / locale
  language  ClinicLanguage @default(en)

  // WhatsApp Business
  whatsappWabaId          String?  @map("whatsapp_waba_id")
  whatsappPhoneNumberId   String?  @map("whatsapp_phone_number_id")
  whatsappConnected       Boolean  @default(false) @map("whatsapp_connected")

  // Reminder toggles (FR-25)
  reminder24hEnabled      Boolean  @default(true) @map("reminder_24h_enabled")
  reminder2hEnabled       Boolean  @default(true) @map("reminder_2h_enabled")

  users         User[]
  staffInvites  StaffInvite[]

  @@map("clinics")
}

model User {
  id        String    @id @default(uuid())
  phone     String    @unique
  name      String?
  role      UserRole
  clinicId  String?   @map("clinic_id")
  createdAt DateTime  @default(now()) @map("created_at")

  clinic    Clinic?   @relation(fields: [clinicId], references: [id])

  @@map("users")
}

model Session {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  expiresAt         DateTime @map("expires_at")
  deviceFingerprint String?  @map("device_fingerprint")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

model OtpAttempt {
  id          String    @id @default(uuid())
  phone       String    @unique
  attempts    Int       @default(0)
  lockedUntil DateTime? @map("locked_until")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("otp_attempts")
}

model StaffInvite {
  id        String       @id @default(uuid())
  clinicId  String       @map("clinic_id")
  phone     String
  role      UserRole
  token     String       @unique
  status    InviteStatus @default(PENDING)
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")

  clinic    Clinic       @relation(fields: [clinicId], references: [id])

  @@map("staff_invites")
}
